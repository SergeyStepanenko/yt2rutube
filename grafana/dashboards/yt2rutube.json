{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Всего видео",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "yt2rutube_videos_total",
          "legendFormat": "total",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Готово (done)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "yt2rutube_videos_by_status{status=\"done\"}",
          "legendFormat": "done",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "В очереди (pending)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "yt2rutube_videos_by_status{status=\"pending\"}",
          "legendFormat": "pending",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Ошибки (error)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "yt2rutube_videos_by_status{status=\"error\"}",
          "legendFormat": "error",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "red", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "В процессе",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "yt2rutube_videos_by_status{status=\"downloading\"} + yt2rutube_videos_by_status{status=\"uploading\"}",
          "legendFormat": "in progress",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "yellow", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Источники",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "yt2rutube_sources_total",
          "legendFormat": "sources",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "purple", "value": null }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "title": "Видео по статусам",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "yt2rutube_videos_by_status",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "donut",
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      }
    },
    {
      "title": "Загрузки в день",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "targets": [
        {
          "expr": "yt2rutube_uploads_daily",
          "legendFormat": "{{date}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80 }
        },
        "overrides": []
      }
    },
    {
      "title": "Ошибки в день",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "targets": [
        {
          "expr": "yt2rutube_errors_daily",
          "legendFormat": "{{date}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80 }
        },
        "overrides": []
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["yt2rutube"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "yt2rutube",
  "uid": "yt2rutube-main",
  "version": 1
}
