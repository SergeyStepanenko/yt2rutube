# Rutube credentials
RUTUBE_EMAIL=your@email.com
RUTUBE_PASSWORD=your_password

# ── Tunnel / Proxy ──────────────────────────────
# Option A: Direct server IP (when running on VPS)
# PUBLIC_URL=http://185.123.45.67:8333

# Option B: SSH reverse tunnel to VPS (when running locally)
VPS_HOST=185.123.45.67
VPS_USER=root
VPS_SSH_PORT=22
VPS_TUNNEL_PORT=8333
VPS_PUBLIC_URL=http://185.123.45.67

# ── MacBook worker (dubbing/ML) ─────────────────
MACBOOK_USER=your_macbook_user
MACBOOK_HOST=192.168.x.x
MACBOOK_PATH=/Users/your_macbook_user/work/yt2rutube

# ── Translation (DeepSeek) ──────────────────────
DEEP_SEEK_API_KEY=your_deepseek_api_key

# ── Transcription / Claude ──────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Ports ───────────────────────────────────────
ADMIN_PORT=3847
SERVE_PORT=8333

# ── Sync settings ──────────────────────────────
SYNC_INTERVAL_MS=3600000
MAX_VIDEOS_PER_CYCLE=5
MAX_RETRIES=3

# Rutube category (2 = Авто-мото)
RUTUBE_CATEGORY_ID=2
